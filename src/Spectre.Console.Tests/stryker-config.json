{
  "stryker-config": {
    "project": "Spectre.Console.csproj",
    "concurrency": 4,
    "target-framework": "net10.0",
    "mutate": [
      "**/*",
      "!src/Spectre.Console/Emoji.cs",
      "!src/Spectre.Console/Widgets/Exceptions/TypeNameHelper.cs",
      "!src/Spectre.Console/Extensions/AnsiConsoleExtensions.Async.cs",
      "!**/Emoji.cs",
      "!**/TypeNameHelper.cs",
      "!**/AnsiConsoleExtensions.Async.cs"
    ]
  }
}
