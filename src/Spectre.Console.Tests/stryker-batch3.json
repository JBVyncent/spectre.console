{
  "stryker-config": {
    "project": "Spectre.Console.csproj",
    "concurrency": 2,
    "target-framework": "net10.0",
    "reporters": ["json", "html", "cleartext"],
    "mutate": [
      "**/Prompts/ConfirmationPrompt.cs",
      "**/Prompts/List/ListPrompt.cs",
      "**/Prompts/List/ListPromptRenderHook.cs",
      "**/Prompts/List/ListPromptState.cs",
      "**/Prompts/List/ListPromptTree.cs",
      "**/Prompts/MultiSelectionPrompt.cs",
      "**/Prompts/SelectionPrompt.cs",
      "**/Rendering/RenderHookScope.cs",
      "**/Rendering/SegmentLine.cs",
      "**/Rendering/SegmentShape.cs",
      "!**/Spectre.Console.Tests/**",
      "!**/Generated/**",
      "!**/Emoji.cs"
    ]
  }
}
